			"defaultPresets": true,
			"presets": [
				{
					"name": "بطاقة خفيفة",
					"slug": "linkawy-card-soft",
					"shadow": "0 2px 10px rgba(0, 0, 0, 0.05)"
				},
				{
					"name": "بطاقة برتقالية",
					"slug": "linkawy-card-brand",
					"shadow": "0 4px 20px rgba(255, 107, 0, 0.12)"
				},
				{
					"name": "زر مرتفع",
					"slug": "linkawy-button-lift",
					"shadow": "0 4px 15px rgba(255, 107, 0, 0.35)"
				}
			]
		},
