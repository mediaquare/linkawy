				},
				{
					"name": "قسم",
					"slug": "section",
					"size": "7rem"
				}
			],
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem"
			}
		},
