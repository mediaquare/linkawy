			"minHeight": true,
			"aspectRatio": true,
			"defaultAspectRatios": true
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px",
			"allowEditing": true,
			"allowCustomContentAndWideSize": true
		},
		"lightbox": {
			"enabled": true,
			"allowEditing": true
		},
		"position": {
			"sticky": true,
			"fixed": true
		},
